{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "raxitadf"
		},
		"ls_address_copy_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_address_copy'"
		},
		"ls_copy_sql_source_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_copy_sql_source'"
		},
		"ls_destination_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_destination'"
		},
		"ls_select_data_generate_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_select_data_generate'"
		},
		"ls_sql_source_tables_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sql_source_tables'"
		},
		"ls_copy_sql_source_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "rxtsqlsrvr.database.windows.net"
		},
		"ls_copy_sql_source_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "db01"
		},
		"ls_copy_sql_source_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "azureuser"
		},
		"ls_select_data_generate_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "rxtsqlsrvr.database.windows.net"
		},
		"ls_select_data_generate_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "db01"
		},
		"ls_select_data_generate_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "azureuser"
		},
		"ls_sql_source_tables_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "rxtsqlsrvr.database.windows.net"
		},
		"ls_sql_source_tables_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "db01"
		},
		"ls_sql_source_tables_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "azureuser"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "raxitadf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_address_copy_connectionString": {
						"value": "[parameters('ls_address_copy_connectionString')]"
					},
					"ls_copy_sql_source_password": {
						"value": "[parameters('ls_copy_sql_source_password')]"
					},
					"ls_destination_connectionString": {
						"value": "[parameters('ls_destination_connectionString')]"
					},
					"ls_select_data_generate_password": {
						"value": "[parameters('ls_select_data_generate_password')]"
					},
					"ls_sql_source_tables_password": {
						"value": "[parameters('ls_sql_source_tables_password')]"
					},
					"ls_copy_sql_source_properties_typeProperties_server": {
						"value": "[parameters('ls_copy_sql_source_properties_typeProperties_server')]"
					},
					"ls_copy_sql_source_properties_typeProperties_database": {
						"value": "[parameters('ls_copy_sql_source_properties_typeProperties_database')]"
					},
					"ls_copy_sql_source_properties_typeProperties_userName": {
						"value": "[parameters('ls_copy_sql_source_properties_typeProperties_userName')]"
					},
					"ls_select_data_generate_properties_typeProperties_server": {
						"value": "[parameters('ls_select_data_generate_properties_typeProperties_server')]"
					},
					"ls_select_data_generate_properties_typeProperties_database": {
						"value": "[parameters('ls_select_data_generate_properties_typeProperties_database')]"
					},
					"ls_select_data_generate_properties_typeProperties_userName": {
						"value": "[parameters('ls_select_data_generate_properties_typeProperties_userName')]"
					},
					"ls_sql_source_tables_properties_typeProperties_server": {
						"value": "[parameters('ls_sql_source_tables_properties_typeProperties_server')]"
					},
					"ls_sql_source_tables_properties_typeProperties_database": {
						"value": "[parameters('ls_sql_source_tables_properties_typeProperties_database')]"
					},
					"ls_sql_source_tables_properties_typeProperties_userName": {
						"value": "[parameters('ls_sql_source_tables_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}